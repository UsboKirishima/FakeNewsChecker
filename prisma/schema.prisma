datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  image         String?
  oauthProvider String
  searches      Search[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Search {
  id          String    @id @default(cuid())
  url         String
  verdict     String
  confidence  Float
  aiComments  String?
  operations  String?
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}
